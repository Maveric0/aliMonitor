[Unit]
Description=aliMonitor WebUI service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/aliMonitor
EnvironmentFile=-/etc/aliMonitor-webui.env
ExecStart=/usr/bin/python3 /opt/aliMonitor/failover_webui.py --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
